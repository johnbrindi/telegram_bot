# Environment secrets — NEVER commit these
.env
*.session
*.session-journal

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Virtual environment
.venv/
venv/
env/

# Logs
logs/
*.log
*.zip

# OS artifacts
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
